     "by", "-", 
     RowBox[{
     "term", "\n", "   ", "at", " ", "several", " ", "generic", " ", 
      "numerical", " ", "points", " ", "and", " ", "also", " ", "check", " ", 
      "the", " ", "total", " ", 
      RowBox[{"energy", "."}]}]}]}], " ", "*)"}], "\n", 
