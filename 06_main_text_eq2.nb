Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"69799c2a-d4d4-4506-9ebb-1b33be8d0ba8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "notebook", " ", "derives", " ", "the", " ", "main"}], "-", 
    RowBox[{"text", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "2", ")"}]}], " ", "for", " ", "a", " ", "general", " ", 
     "parallelogram", " ", 
     RowBox[{"flake", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "All", " ", "symbols", " ", "are", " ", "kept", " ", "in", " ", "ASCII", 
    " ", "so", " ", "the", " ", "notebook", " ", "is", " ", "easy", " ", "to",
     " ", "read", " ", "and", " ", 
    RowBox[{"edit", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "dx", ",", " ", "dy", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb", ",", " ", "lambda", ",", " ", "xi1", ",", 
          " ", "xi2", ",", " ", "phi", ",", " ", "eta"}], "}"}], ",", " ", 
        "Reals"}], "]"}], " ", "&&", "\n", "  ", 
      RowBox[{"rb", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"lambda", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"xi1", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"xi2", " ", ">", " ", "0"}], " ", "&&", "\n", "  ", 
      RowBox[{"0", " ", "<", " ", "theta", " ", "<", " ", "Pi"}], " ", "&&", 
      " ", 
      RowBox[{"0", " ", "<", " ", "phi", " ", "<", " ", 
       RowBox[{"Pi", "/", "2"}]}], " ", "&&", " ", 
      RowBox[{
       RowBox[{"1", " ", "+", " ", 
        RowBox[{"2", " ", 
         RowBox[{"Cos", "[", 
          RowBox[{"2", " ", "phi"}], "]"}]}]}], " ", "!=", " ", "0"}]}]}], 
    ";"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"cf61879a-355f-4802-90a8-9bfebd35164a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Density Decomposition", "Section",ExpressionUUID->"9b02680a-97b5-4580-9efa-7cc8f6edb191"],

Cell["\<\
The identity 2 Cos[A] Cos[B] = Cos[A+B] + Cos[A-B] turns the density into \
three Fourier terms. Eq. (2) is the sum of the three corresponding area \
integrals.\
\>", "Text",ExpressionUUID->"21dfc845-c149-405f-9fc7-016e6520d613"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "lambda0", " ", "is", " ", "the", " ", "moire", " ", "wavelength", " ", 
    "before", " ", "the", " ", "final", " ", "rescaling", " ", "to", " ", 
    RowBox[{"lambda", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"lambda0", "[", 
      RowBox[{"theta_", ",", " ", "rb_"}], "]"}], " ", ":=", " ", 
     RowBox[{"rb", "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"theta", "/", "2"}], "]"}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "The", " ", "translated", " ", "moire", " ", "density", " ", "used", " ", 
     "in", " ", "the", " ", "old", " ", 
     RowBox[{"notebook", "."}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"phaseA", "[", 
      RowBox[{
      "x_", ",", " ", "y_", ",", " ", "sx_", ",", " ", "sy_", ",", " ", 
       "theta_", ",", " ", "rb_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{"2", " ", "Pi", " ", 
      RowBox[{"(", 
       RowBox[{"sy", " ", "+", " ", 
        RowBox[{"2", " ", "y"}], " ", "-", " ", 
        RowBox[{"sx", " ", 
         RowBox[{"Cot", "[", 
          RowBox[{"theta", "/", "2"}], "]"}]}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"theta", "/", "2"}], "]"}], "/", "rb"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"phaseB", "[", 
      RowBox[{
      "x_", ",", " ", "y_", ",", " ", "sx_", ",", " ", "sy_", ",", " ", 
       "theta_", ",", " ", "rb_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{"2", " ", "Pi", " ", 
      RowBox[{"(", 
       RowBox[{"sx", " ", "+", " ", 
        RowBox[{"2", " ", "x"}], " ", "+", " ", 
        RowBox[{"sy", " ", 
         RowBox[{"Cot", "[", 
          RowBox[{"theta", "/", "2"}], "]"}]}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"theta", "/", "2"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"phaseC", "[", 
      RowBox[{
      "x_", ",", " ", "y_", ",", " ", "sx_", ",", " ", "sy_", ",", " ", 
       "theta_", ",", " ", "rb_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{"(", 
       RowBox[{"sx", " ", "+", " ", 
        RowBox[{"2", " ", "x"}], " ", "+", " ", 
        RowBox[{"sy", " ", 
         RowBox[{"Cot", "[", 
          RowBox[{"theta", "/", "2"}], "]"}]}]}], ")"}], " ", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"theta", "/", "2"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"densityOriginal", " ", "=", " ", 
     RowBox[{
      RowBox[{"2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"phaseA", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}], "]"}], " ", "*", "\n", "    ", 
       RowBox[{"Cos", "[", 
        RowBox[{"phaseB", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}], "]"}]}], " ", "+", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{"phaseC", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"densityDecomposed", " ", "=", " ", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"phaseA", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}], " ", "+", " ", 
        RowBox[{"phaseB", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}]}], "]"}], " ", "+", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"phaseA", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}], " ", "-", " ", 
        RowBox[{"phaseB", "[", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", 
          "theta", ",", " ", "rb"}], "]"}]}], "]"}], " ", "+", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{"phaseC", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"densityIdentity", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"TrigExpand", "[", 
       RowBox[{"densityOriginal", " ", "-", " ", "densityDecomposed"}], "]"}],
       " ", "==", " ", "0"}], "]"}]}]}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"7e37cc74-9bb9-4ddc-b7fb-15253af84178"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.987720004023038*^9, 3.9877247352892957`*^9},
 CellLabel->"Out[9]=",ExpressionUUID->"8f9e91fa-29a3-4f8b-b8b4-9ff96d1f63be"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Parallelogram Region", "Section",ExpressionUUID->"95ed25bd-6248-4e52-b1c4-a8496c9b40c2"],

Cell["\<\
The parameterization below represents the general parallelogram used in the \
paper. Its area is (Sqrt[3]/2) xi1 xi2 lambda0^2 before rescaling to the \
arbitrary wavelength lambda.\
\>", "Text",ExpressionUUID->"235ab609-c337-4c31-a0bd-9b4724c37a36"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Parameterize", " ", "the", " ", "parallelogram", " ", "by", " ", "u"}], 
    ",", 
    RowBox[{"v", " ", 
     RowBox[{
      RowBox[{"in", " ", "[", 
       RowBox[{"0", ",", "1"}], "]"}], ".", "\n", "   ", "The"}], " ", "two", 
     " ", "side", " ", "vectors", " ", "are", " ", 
     RowBox[{"(", 
      RowBox[{"height", ",", " ", 
       RowBox[{"height", " ", 
        RowBox[{"Cot", "[", "phi", "]"}]}]}], ")"}], " ", "and", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"0", ",", " ", 
        RowBox[{"xi2", " ", "lambda0"}]}], ")"}], "."}]}]}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"height", " ", "=", " ", 
     RowBox[{
      RowBox[{"Sqrt", "[", "3", "]"}], " ", "xi1", " ", 
      RowBox[{
       RowBox[{"lambda0", "[", 
        RowBox[{"theta", ",", " ", "rb"}], "]"}], "/", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"xUV", " ", "=", " ", 
     RowBox[{"height", " ", "u"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"yUV", " ", "=", " ", 
     RowBox[{
      RowBox[{"height", " ", "u", " ", 
       RowBox[{"Cot", "[", "phi", "]"}]}], " ", "+", " ", 
      RowBox[{"xi2", " ", 
       RowBox[{"lambda0", "[", 
        RowBox[{"theta", ",", " ", "rb"}], "]"}], " ", "v"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"jacobian", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"xUV", ",", " ", "u"}], "]"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"yUV", ",", " ", "v"}], "]"}]}], " ", "-", " ", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"xUV", ",", " ", "v"}], "]"}], " ", 
        RowBox[{"D", "[", 
         RowBox[{"yUV", ",", " ", "u"}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"areaMoire", " ", "=", " ", 
