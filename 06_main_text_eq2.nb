Cell[CellGroupData[{

Cell["Generic Cosine Integral", "Section",ExpressionUUID->"be870a53-3f63-4126-80b0-02593dbee62a"],

Cell["\<\
After substituting the parallelogram coordinates, each phase is linear in u \
and v. The following two formulas are the only integration identities needed \
in the rest of the notebook.\
\>", "Text",ExpressionUUID->"5f753f99-9332-4c3e-8021-67430e67edaf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "A", " ", "cosine", " ", "with", " ", "linear", " ", "phase", " ", "can", 
     " ", "be", " ", "integrated", " ", "analytically", " ", 
     RowBox[{"once", ".", "\n", "   ", "The"}], " ", "third", " ", "density", 
     " ", "term", " ", "has", " ", "no", " ", "v", " ", "dependence"}], ",", 
    " ", 
    RowBox[{"so", " ", "it", " ", "uses", " ", "the", " ", "1", "D", " ", 
     RowBox[{"version", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"integral2D", "[", 
      RowBox[{"a_", ",", " ", "b_", ",", " ", "c_"}], "]"}], " ", ":=", " ", 
     RowBox[{"4", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"a", "/", "2"}], "]"}], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"b", "/", "2"}], "]"}], " ", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"c", " ", "+", " ", 
         RowBox[{"a", "/", "2"}], " ", "+", " ", 
         RowBox[{"b", "/", "2"}]}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"a", " ", "b"}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"integral1D", "[", 
      RowBox[{"a_", ",", " ", "c_"}], "]"}], " ", ":=", " ", 
     RowBox[{"2", " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"a", "/", "2"}], "]"}], " ", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"c", " ", "+", " ", 
         RowBox[{"a", "/", "2"}]}], "]"}], "/", "a"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"checkIntegralFormulas", " ", "=", " ", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"FullSimplify", "[", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{"Integrate", "[", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"c", " ", "+", " ", 
             RowBox[{"a", " ", "u"}], " ", "+", " ", 
             RowBox[{"b", " ", "v"}]}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"u", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"v", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
           RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}], 
         " ", "==", "\n", "      ", 
         RowBox[{"integral2D", "[", 
          RowBox[{"a", ",", " ", "b", ",", " ", "c"}], "]"}]}], ",", "\n", 
        "    ", 
        RowBox[{
         RowBox[{"Element", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"a", ",", " ", "b", ",", " ", "c"}], "}"}], ",", " ", 
           "Reals"}], "]"}], " ", "&&", " ", 
         RowBox[{"a", " ", "!=", " ", "0"}], " ", "&&", " ", 
         RowBox[{"b", " ", "!=", " ", "0"}]}]}], "\n", "  ", "]"}], ",", "\n",
       "  ", 
      RowBox[{"FullSimplify", "[", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{"Integrate", "[", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"c", " ", "+", " ", 
             RowBox[{"a", " ", "u"}]}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"u", ",", " ", "0", ",", " ", "1"}], "}"}], ",", " ", 
           RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "]"}], 
         " ", "==", "\n", "      ", 
         RowBox[{"integral1D", "[", 
          RowBox[{"a", ",", " ", "c"}], "]"}]}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"Element", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"a", ",", " ", "c"}], "}"}], ",", " ", "Reals"}], "]"}], 
         " ", "&&", " ", 
         RowBox[{"a", " ", "!=", " ", "0"}]}]}], "\n", "  ", "]"}]}], "\n", 
     "}"}]}]}]}]], "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"fef3592a-b569-49ca-a2d7-e4cbf45e993b"],

