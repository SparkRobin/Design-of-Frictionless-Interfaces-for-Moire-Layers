      RowBox[{
       RowBox[{"phaseA", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}], " ", "-", " ", 
       RowBox[{"phaseB", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
     "\"\<Cos[phaseC] coefficients {u,v,const}\>\"", " ", "->", " ", 
      "coeffC"}], ",", "\n", "  ", 
