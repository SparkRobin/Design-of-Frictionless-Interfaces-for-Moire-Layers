     "\"\<Cos[phaseA + phaseB] coefficients\>\"", " ", "->", " ", 
      "coeffPlus"}], ",", "\n", "  ", 
     RowBox[{
     "\"\<Cos[phaseA - phaseB] coefficients\>\"", " ", "->", " ", 
