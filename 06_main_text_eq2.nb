Cell[CellGroupData[{

Cell["Three Phase Coefficients", "Section",ExpressionUUID->"18abcd1b-32ee-43c3-98bc-61b82fff1247"],

Cell["\<\
The translation rotation matches the convention used in the main-text \
formula. The coefficient triples are {coefficient of u, coefficient of v, \
constant phase}.\
\>", "Text",ExpressionUUID->"70487578-a978-4a9f-a806-4db1ac9caf79"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Rotate", " ", "the", " ", "translation", " ", "components", " ", "into", 
    " ", "the", " ", "convention", " ", "used", " ", "in", " ", "the", " ", 
    RowBox[{"paper", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"translationRotation", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"sx", " ", "->", " ", 
        RowBox[{
         RowBox[{"dx", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"-", "theta"}], "/", "2"}], "]"}]}], " ", "-", " ", 
         RowBox[{"dy", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"-", "theta"}], "/", "2"}], "]"}]}]}]}], ",", "\n", "  ", 
       RowBox[{"sy", " ", "->", " ", 
        RowBox[{
         RowBox[{"dy", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{
            RowBox[{"-", "theta"}], "/", "2"}], "]"}]}], " ", "+", " ", 
         RowBox[{"dx", " ", 
          RowBox[{"Sin", "[", 
           RowBox[{
            RowBox[{"-", "theta"}], "/", "2"}], "]"}]}]}]}]}], "\n", "}"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"phaseToCoefficients", "[", "phase_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "p", "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"p", " ", "=", " ", 
         RowBox[{"FullSimplify", "[", 
          RowBox[{"Collect", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"phase", " ", "/.", " ", "translationRotation"}], ")"}],
              " ", "/.", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"x", " ", "->", " ", "xUV"}], ",", " ", 
               RowBox[{"y", " ", "->", " ", "yUV"}]}], "}"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"u", ",", " ", "v"}], "}"}]}], "]"}], "]"}]}], ";", "\n",
         "  ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"FullSimplify", "[", 
           RowBox[{"Coefficient", "[", 
            RowBox[{"p", ",", " ", "u"}], "]"}], "]"}], ",", " ", 
          RowBox[{"FullSimplify", "[", 
           RowBox[{"Coefficient", "[", 
            RowBox[{"p", ",", " ", "v"}], "]"}], "]"}], ",", "\n", "   ", 
          RowBox[{"FullSimplify", "[", 
           RowBox[{"p", " ", "/.", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"u", " ", "->", " ", "0"}], ",", " ", 
              RowBox[{"v", " ", "->", " ", "0"}]}], "}"}]}], "]"}]}], 
         "}"}]}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"coeffC", " ", "=", " ", 
     RowBox[{"phaseToCoefficients", "[", 
      RowBox[{"phaseC", "[", 
       RowBox[{
       "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta", 
        ",", " ", "rb"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coeffPlus", " ", "=", " ", 
     RowBox[{"phaseToCoefficients", "[", 
      RowBox[{
       RowBox[{"phaseA", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}], " ", "+", " ", 
       RowBox[{"phaseB", "[", 
        RowBox[{
        "x", ",", " ", "y", ",", " ", "sx", ",", " ", "sy", ",", " ", "theta",
          ",", " ", "rb"}], "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coeffMinus", " ", "=", " ", 
