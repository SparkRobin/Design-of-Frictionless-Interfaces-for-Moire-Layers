Notebook[{

Cell[CellGroupData[{
Cell["06 Main-Text Eq. (2)", "Title",ExpressionUUID->"d0440c95-76cb-4659-814b-2639917b030a"],

Cell["\<\
This notebook derives the general parallelogram energy formula printed as Eq. \
(2) in the main text.\
\>", "Text",
 CellChangeTimes->{
  3.987724697770933*^9},ExpressionUUID->"53a47bf3-df0c-4bb7-9d0a-\
492d21ec3c66"],

Cell[TextData[{
 "Reader map: decompose the translated moire density into three cosine terms, \
parameterize the parallelogram by two unit variables, integrate a generic \
linear-phase cosine once, and apply it to the three density terms. The final \
section compares the result with the published Eq. (2).\n",
 Cell[BoxData[
