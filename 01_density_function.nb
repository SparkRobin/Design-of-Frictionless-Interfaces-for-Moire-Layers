        RowBox[{"y", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "rb"], 
    "]"}]}]}]], "Output",
 CellChangeTimes->{3.9877164647066402`*^9},
 CellLabel->"Out[11]=",ExpressionUUID->"5f8790a6-8086-48b8-805e-92814a821f42"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"checkS2", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"TrigReduce", "[", 
      RowBox[{"rhoS2Derived", " ", "-", " ", "rhoS2Target"}], "]"}], " ", "==",
