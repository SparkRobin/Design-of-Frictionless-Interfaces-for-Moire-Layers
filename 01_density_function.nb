Notebook[{

Cell[CellGroupData[{
Cell["01 Density Function", "Title",ExpressionUUID->"b5e34805-8fd8-4bd2-b716-8178d9c22d62"],

Cell["\<\
This notebook derives the translated moire energy density. It reproduces SI \
Eq. (S1) and its homobilayer limit Eq. (S2).\
\>", "Text",ExpressionUUID->"0a3bf9a4-3a7e-413e-bd7e-1ed3c9db50b0"],

Cell["\<\
Reader map: start from the energy density rho0 in the moire coordinate \
system, write the translated moire coordinates in the substrate coordinate \
system, substitute them into rho0, and then check the result against Eq. \
(S1). Setting p = 1 gives the homobilayer formula Eq. (S2).\
\>", "Text",ExpressionUUID->"fb4aad27-9f5d-4180-b59f-428f1b256dbb"],

Cell[CellGroupData[{

Cell["Derivation", "Section",ExpressionUUID->"7dba5430-d0f0-4611-a111-b025e0f4e504"],

Cell["\<\
The symbols dx and dy are the imposed translation components Delta x and \
Delta y. The parameter rb denotes |Rb|, p is the lattice-constant ratio, \
theta is the twist angle, and eta only sets the sign/amplitude of the moire \
density.\
\>", "Text",ExpressionUUID->"4b08070f-fe2b-48c5-a28c-fdb300627aed"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "notebook", " ", "derives", " ", "the", " ", "translated", 
    " ", "moire", " ", "energy", " ", "density", " ", "used", " ", "in", " ", 
    "the", " ", 
    RowBox[{"paper", "."}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "variables", " ", "dx", " ", "and", " ", "dy", " ", "denote", 
    " ", "the", " ", "imposed", " ", "flake", " ", "translation", " ", 
    "components", " ", "Delta", " ", "x", " ", "and", " ", "Delta", " ", 
    RowBox[{"y", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "x", ",", " ", "y", ",", " ", "dx", ",", " ", "dy", ",", " ", 
          "theta", ",", " ", "p", ",", " ", "rb", ",", " ", "eta"}], "}"}], 
        ",", " ", "Reals"}], "]"}], " ", "&&", " ", 
      RowBox[{"rb", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"p", " ", ">", " ", "0"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"6a65ffe9-8275-4026-bbcf-f157fe5e2fa7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"lambda", "[", 
    RowBox[{"theta_", ",", " ", "p_", ",", " ", "rb_"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{"p", " ", 
    RowBox[{"rb", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", " ", "+", " ", 
       RowBox[{"p", "^", "2"}], " ", "-", " ", 
       RowBox[{"2", " ", "p", " ", 
        RowBox[{"Cos", "[", "theta", "]"}]}]}], "]"}]}]}]}], ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"59e1851d-f58c-466c-b014-ee67169045b7"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rho0", "[", 
    RowBox[{"xp_", ",", " ", "yp_", ",", " ", "lam_"}], "]"}], " ", ":=", " ", 
   RowBox[{"eta", " ", 
    RowBox[{"(", "\n", "  ", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{"xp", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "lam"}], ")"}]}]}], "]"}], 
      " ", "+", "\n", "  ", 
      RowBox[{"2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{"xp", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sqrt", "[", "3", "]"}], " ", "lam"}], ")"}]}]}], "]"}], 
       " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{"yp", "/", "lam"}]}], "]"}]}]}], "\n", ")"}]}]}], 
  ";"}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"9b18c2ed-46ae-49d0-a2f8-23f2b8da8675"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Write", " ", "the", " ", "transformed", " ", "moire", " ", "coordinates", 
    " ", "as", " ", 
    RowBox[{"xPrime", "/", "lambda"}], " ", "and", " ", 
    RowBox[{"yPrime", "/", 
     RowBox[{"lambda", ".", "\n", "   ", "This"}]}], " ", "form", " ", 
    "cancels", " ", "lambda", " ", "cleanly", " ", "and", " ", "gives", " ", 
    "the", " ", "compact", " ", "SI", " ", 
    RowBox[{"Eq", ".", " ", 
     RowBox[{"(", "S1", ")"}], "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"xPrime", " ", "=", " ", 
     RowBox[{
      RowBox[{"lambda", "[", 
       RowBox[{"theta", ",", " ", "p", ",", " ", "rb"}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", " ", 
          RowBox[{"(", 
           RowBox[{"y", " ", "+", " ", "dy"}], ")"}]}], " ", "-", " ", 
         RowBox[{"y", " ", 
          RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
         RowBox[{"x", " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", "rb"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"yPrime", " ", "=", " ", 
     RowBox[{
      RowBox[{"lambda", "[", 
       RowBox[{"theta", ",", " ", "p", ",", " ", "rb"}], "]"}], " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "p"}], " ", 
          RowBox[{"(", 
           RowBox[{"x", " ", "+", " ", "dx"}], ")"}]}], " ", "+", " ", 
         RowBox[{"x", " ", 
          RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
         RowBox[{"y", " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", "rb"}]}]}], 
    ";"}]}]}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"446724cb-ff02-4888-b5d4-548c5ba3eb28"],

Cell[BoxData[
 RowBox[{
  RowBox[{"rhoS1Derived", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"rho0", "[", 
     RowBox[{"xPrime", ",", " ", "yPrime", ",", " ", 
      RowBox[{"lambda", "[", 
       RowBox[{"theta", ",", " ", "p", ",", " ", "rb"}], "]"}]}], "]"}], 
    "]"}]}], ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"82d62557-70ec-498b-a5a8-e16a354cc270"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"rhoS1Target", " ", "=", " ", 
  RowBox[{
   RowBox[{"2", " ", "eta", " ", "*", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "Pi", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", " ", "y"}], " ", "+", " ", 
         RowBox[{"p", " ", "dy"}], " ", "-", " ", 
         RowBox[{"y", " ", 
          RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
         RowBox[{"x", " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], "]"}], " ", 
    "*", "\n", "  ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", " ", "Pi", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "p"}], " ", "x"}], " ", "-", " ", 
         RowBox[{"p", " ", "dx"}], " ", "+", " ", 
         RowBox[{"x", " ", 
          RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
         RowBox[{"y", " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", "rb"}]}], 
     "]"}]}], " ", "+", "\n", "  ", 
   RowBox[{"eta", " ", "*", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"4", " ", "Pi", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"p", " ", "y"}], " ", "+", " ", 
         RowBox[{"p", " ", "dy"}], " ", "-", " ", 
         RowBox[{"y", " ", 
          RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
         RowBox[{"x", " ", 
          RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], 
     "]"}]}]}]}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"e5b93ce4-3422-4fd4-a7f6-6a315b018546"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eta", " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"4", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"dy", " ", "p"}], "+", 
        RowBox[{"p", " ", "y"}], "-", 
        RowBox[{"y", " ", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "+", 
        RowBox[{"x", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], 
     RowBox[{
      SqrtBox["3"], " ", "rb"}]], "]"}]}], "+", 
  RowBox[{"2", " ", "eta", " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"2", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"dy", " ", "p"}], "+", 
        RowBox[{"p", " ", "y"}], "-", 
        RowBox[{"y", " ", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "+", 
        RowBox[{"x", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], 
     RowBox[{
      SqrtBox["3"], " ", "rb"}]], "]"}], " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"2", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "dx"}], " ", "p"}], "-", 
        RowBox[{"p", " ", "x"}], "+", 
        RowBox[{"x", " ", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "+", 
        RowBox[{"y", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], "rb"], 
    "]"}]}]}]], "Output",
 CellChangeTimes->{3.987716354713973*^9},
 CellLabel->"Out[8]=",ExpressionUUID->"be53c983-2dca-4dba-a826-b4cff3682856"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"checkS1", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"TrigReduce", "[", 
      RowBox[{"rhoS1Derived", " ", "-", " ", "rhoS1Target"}], "]"}], " ", "==",
      " ", "0"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"46a3afea-41a9-4c63-9c9e-eb3df029096f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Homobilayer", " ", "limit", " ", "p"}], " ", "=", " ", 
    RowBox[{"1", " ", "gives", " ", "SI", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "S2", ")"}], "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"rhoS2Derived", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"rhoS1Derived", " ", "/.", " ", 
       RowBox[{"p", " ", "->", " ", "1"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"rhoS2Target", " ", "=", " ", 
    RowBox[{
     RowBox[{"2", " ", "eta", " ", "*", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", " ", "+", " ", "dy", " ", "-", " ", 
           RowBox[{"y", " ", 
            RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
           RowBox[{"x", " ", 
            RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], "]"}], 
      " ", "*", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "x"}], " ", "-", " ", "dx", " ", "+", " ", 
           RowBox[{"x", " ", 
            RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
           RowBox[{"y", " ", 
            RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", "rb"}]}], 
       "]"}]}], " ", "+", "\n", "  ", 
     RowBox[{"eta", " ", "*", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", " ", "+", " ", "dy", " ", "-", " ", 
           RowBox[{"y", " ", 
            RowBox[{"Cos", "[", "theta", "]"}]}], " ", "+", " ", 
           RowBox[{"x", " ", 
            RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], 
       "]"}]}]}]}]}]}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"27a91105-b60b-46ef-b884-9565a1e0f91e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"eta", " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"4", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{"dy", "+", "y", "-", 
        RowBox[{"y", " ", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "+", 
        RowBox[{"x", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], 
     RowBox[{
      SqrtBox["3"], " ", "rb"}]], "]"}]}], "+", 
  RowBox[{"2", " ", "eta", " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"2", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{"dy", "+", "y", "-", 
        RowBox[{"y", " ", 
         RowBox[{"Cos", "[", "theta", "]"}]}], "+", 
        RowBox[{"x", " ", 
         RowBox[{"Sin", "[", "theta", "]"}]}]}], ")"}]}], 
     RowBox[{
      SqrtBox["3"], " ", "rb"}]], "]"}], " ", 
   RowBox[{"Cos", "[", 
    FractionBox[
     RowBox[{"2", " ", "\[Pi]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "dx"}], "-", "x", "+", 
        RowBox[{"x", " ", 
