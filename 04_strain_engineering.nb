Notebook[{

Cell[CellGroupData[{
Cell["04 Strain Engineering", "Title",ExpressionUUID->"065d169c-9da9-42bf-a47c-bc7a2010988c"],

Cell["\<\
This notebook verifies the strain-engineering formulas in SI Sec. XIII: the \
biaxial square-flake energy and force, and the uniaxial rectangular-flake \
energy and force.\
\>", "Text",ExpressionUUID->"d6608566-ad13-4994-bfee-0ae240f5d0e7"],

Cell["\<\
Reader map: for biaxial strain, first substitute the strain-dependent moire \
wavelength and square-flake xi values into the phi = 90 degree parallelogram \
formula, then differentiate with respect to dx. For uniaxial strain, directly \
integrate the one-dimensional density over the strained rectangle and again \
differentiate with respect to dx.\
\>", "Text",ExpressionUUID->"5ba72b64-1c1a-40d2-9909-84d989e6a361"],

Cell[CellGroupData[{

Cell["Biaxial and Uniaxial Strain Checks", "Section",ExpressionUUID->"3502cbfe-f6d7-46fa-8924-fbfe3247d9a9"],

Cell["\<\
The variables eps, L0, H0, rb, dx, and dy denote strain, original flake \
length, flake height, graphene lattice length |Rb|, and translation \
components. The final numerical estimate uses rb = 0.246 nm and L0 = 100 nm \
to connect the sine-prefactor zeros with the strain scale discussed in the \
paper.\
\>", "Text",ExpressionUUID->"38c6a740-2edd-4969-bc3e-31fe7c3f39a8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "notebook", " ", "verifies", " ", "the", " ", "strain"}], 
    "-", 
    RowBox[{"engineering", " ", "formulas", " ", "in", " ", "SI", " ", 
     RowBox[{"Sec", ".", " ", "XIII", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"We", " ", "use", " ", "eta"}], " ", "=", " ", 
    RowBox[{
    "1", " ", "because", " ", "the", " ", "SI", " ", "strain", " ", 
     "formulas", " ", "are", " ", "written", " ", "without", " ", "the", " ", 
     "overall", " ", "density", " ", 
     RowBox[{"amplitude", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "dx", ",", " ", "dy", ",", " ", "eps", ",", " ", "L0", ",", " ", 
          "rb", ",", " ", "H0", ",", " ", "lambda", ",", " ", "xi1", ",", " ",
           "xi2"}], "}"}], ",", " ", "Reals"}], "]"}], " ", "&&", "\n", "  ", 
      RowBox[{"eps", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"L0", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"rb", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"H0", " ", ">", " ", "0"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"dd815431-1fdd-4d6a-a5fe-e7d498f25531"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Biaxial", " ", "strain", " ", "changes", " ", "the", " ", "moire", " ", 
    "wavelength", " ", "and", " ", "the", " ", "square", " ", "flake", " ", 
    RowBox[{"parameters", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"lambdaStrain", " ", "=", " ", 
     RowBox[{"rb", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", " ", "+", " ", "eps"}], ")"}], "/", "eps"}]}]}], ";"}], 
   "\n", 
   RowBox[{
