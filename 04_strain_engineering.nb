Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"This", " ", "is", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "S3", ")"}]}], " ", "after", " ", "setting", " ", "phi"}], 
    " ", "=", " ", 
