           RowBox[{"Cos", "[", 
            RowBox[{
             RowBox[{"Pi", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"2", " ", 
                  RowBox[{"Sqrt", "[", "3", "]"}], " ", "dx"}], " ", "+", " ", 
                 RowBox[{"2", " ", "dy"}]}], ")"}], "/", 
