      RowBox[{"eps", "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"xi2Biaxial", " ", "=", " ", 
     RowBox[{"L0", " ", 
      RowBox[{"eps", "/", "rb"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"69077aa9-0679-471c-ade9-880f650f9ea4"],

