    " ", "sliding", " ", "force", " ", 
    RowBox[{"Eq", ".", " ", 
     RowBox[{"(", "S24", ")"}], "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"uniaxialFrictionFromDerivative", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
