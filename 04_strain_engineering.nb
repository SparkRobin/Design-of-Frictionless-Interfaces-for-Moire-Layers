    RowBox[{"Sin", "[", 
     RowBox[{"Pi", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"dx", "/", 
          RowBox[{"(", 
           RowBox[{"rb", " ", 
            RowBox[{"(", 
             RowBox[{"1", " ", "+", " ", "eps"}], ")"}]}], ")"}]}]}], " ", 
        "+", " ", 
        RowBox[{"L0", " ", 
