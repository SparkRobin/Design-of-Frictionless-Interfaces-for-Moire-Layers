Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"checkS23", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"TrigReduce", "[", 
      RowBox[{
      "uniaxialEnergyFromIntegral", " ", "-", " ", "uniaxialEnergyS23"}], 
      "]"}], " ", "==", " ", "0"}], ",", " ", "$Assumptions"}], 
   "]"}]}]], "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"62a18f0c-bdba-4749-9332-644aa0139239"],

