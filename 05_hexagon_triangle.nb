}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"checkTri0", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"TrigReduce", "[", 
      RowBox[{"tri0Derived", " ", "-", " ", "tri0Equivalent"}], "]"}], " ", "==",
      " ", "0"}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[17]:=",ExpressionUUID->"9ca38290-0309-4228-8b5d-935d980bcfbe"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"tri30Energy", " ", "=", " ", 
   RowBox[{"3", " ", 
    RowBox[{"Sqrt", "[", "3", "]"}], " ", "eta", " ", 
    RowBox[{"lam", "^", "2"}], " ", 
    RowBox[{"(", "\n", "  ", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{"dym", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], "]"}], 
      " ", "+", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"Sqrt", "[", "3", "]"}], " ", "dxm"}], " ", "+", " ", 
           "dym", " ", "-", " ", 
           RowBox[{"rb", " ", "xi"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], "]"}], 
      " ", "+", "\n", "  ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Sqrt", "[", "3", "]"}]}], " ", "dxm"}], " ", "+", " ", 
           "dym", " ", "+", " ", 
           RowBox[{"rb", " ", "xi"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "rb"}], ")"}]}]}], "]"}]}], 
     "\n", ")"}], " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", " ", 
        RowBox[{"xi", "/", 
         RowBox[{"Sqrt", "[", "3", "]"}]}]}], "]"}], "^", "2"}], "/", 
     RowBox[{"(", 
      RowBox[{"4", " ", 
       RowBox[{"Pi", "^", "2"}]}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tri30MagicCheck", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"tri30Energy", " ", "/.", " ", 
        RowBox[{"xi", " ", "->", " ", 
         RowBox[{
          RowBox[{"Sqrt", "[", "3", "]"}], " ", "k"}]}]}], ")"}], " ", "==", 
      " ", "0"}], ",", "\n", "  ", 
     RowBox[{"Assumptions", " ", "->", " ", 
      RowBox[{
       RowBox[{"Element", "[", 
        RowBox[{"k", ",", " ", "Integers"}], "]"}], " ", "&&", " ", 
       RowBox[{"k", " ", ">", " ", "0"}], " ", "&&", " ", 
       RowBox[{"lam", " ", ">", " ", "0"}], " ", "&&", " ", 
       RowBox[{"rb", " ", ">", " ", "0"}]}]}]}], "\n", "]"}]}], 
  ";"}]}], "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"4194092e-eecc-4c70-8706-348547533a5f"],

