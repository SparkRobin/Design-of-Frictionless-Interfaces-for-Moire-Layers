  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "phi", ",", " ", "xi", ",", " ", "lam", ",", " ", "eta", ",", " ", 
          "dxm", ",", " ", "dym", ",", " ", "rb"}], "}"}], ",", " ", 
        "Reals"}], "]"}], " ", "&&", " ", 
      RowBox[{"xi", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"lam", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"rb", " ", ">", " ", "0"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"9888c8d7-b6b5-4655-a991-814c9a2b6ade"],

