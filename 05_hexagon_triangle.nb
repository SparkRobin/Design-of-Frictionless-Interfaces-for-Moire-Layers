         SqrtBox["3"], " ", "lam"}]], "+", 
       RowBox[{"2", " ", "\[Pi]", " ", "xi"}]}], "]"}], "-", 
     RowBox[{"2", " ", "\[Pi]", " ", "xi", " ", 
      RowBox[{"Sin", "[", 
       FractionBox[
        RowBox[{"4", " ", "dym", " ", "\[Pi]"}], 
        RowBox[{
         SqrtBox["3"], " ", "lam"}]], "]"}]}], "+", 
     RowBox[{"4", " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"\[Pi]", " ", 
        RowBox[{"(", 
         RowBox[{
          FractionBox[
           RowBox[{"2", " ", "dxm"}], "lam"], "+", "xi"}], ")"}]}], "]"}], 
      " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", 
          FractionBox[
           RowBox[{"2", " ", "dym", " ", "\[Pi]"}], 
           RowBox[{
            SqrtBox["3"], " ", "lam"}]], "]"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Pi]", " ", "xi", " ", 
            RowBox[{"Cos", "[", 
             RowBox[{"\[Pi]", " ", "xi"}], "]"}]}], "-", 
           RowBox[{"Sin", "[", 
            RowBox[{"\[Pi]", " ", "xi"}], "]"}]}], ")"}]}], "+", 
        RowBox[{"\[Pi]", " ", "xi", " ", 
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"2", " ", "dym", " ", "\[Pi]"}], 
           RowBox[{
            SqrtBox["3"], " ", "lam"}]], "]"}], " ", 
         RowBox[{"Sin", "[", 
          RowBox[{"\[Pi]", " ", "xi"}], "]"}]}]}], ")"}]}]}], 
    ")"}]}]}]], "Output",
 CellChangeTimes->{3.9877165043255186`*^9, 3.9877245812762947`*^9},
