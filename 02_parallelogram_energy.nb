Notebook[{

Cell[CellGroupData[{
Cell["02 Parallelogram Energy", "Title",ExpressionUUID->"5bc2cc2a-35ef-4494-bc7e-cf9693b0293a"],

Cell["\<\
This notebook keeps the calculation simple: it directly integrates the \
60-degree parallelogram and checks the directional and all-direction integer \
limits.\
\>", "Text",ExpressionUUID->"c1f30cb0-c36c-49a1-a13b-336bd5d316cf"],

Cell["\<\
Reader map: this is not the full general Eq. (2). It is the clean 60-degree \
special case, which is enough to show how the area integral produces the \
directional-frictionless terms and why integer xi1/xi2 remove the \
translational corrugation.\
\>", "Text",ExpressionUUID->"73973a69-2373-4579-ad0b-1b334a8a1fb0"],

Cell[CellGroupData[{

Cell["60-Degree Direct Integral", "Section",ExpressionUUID->"8ad143a1-6664-4fe9-99f1-c01286618c8f"],

Cell["\<\
The integration region is a parallelogram with base xi2 lambda and height \
Sqrt[3] xi1 lambda/2. The final association reports the two directional \
limits, then the all-direction zero-energy limit when both parameters are \
integers.\
\>", "Text",ExpressionUUID->"f0ed3a9e-3df5-4cc2-a639-1a3e7ffe404c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "notebook", " ", "derives", " ", "the", " ", "simple", " ", 
     "60"}], "-", 
    RowBox[{
    "degree", " ", "parallelogram", " ", "energy", " ", "directly", " ", "by",
      " ", 
     RowBox[{"integration", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "It", " ", "intentionally", " ", "does", " ", "not", " ", "try", " ", 
     "to", " ", "rederive", " ", "the", " ", "fully", " ", "general", " ", 
     RowBox[{"Eq", ".", " ", 
      RowBox[{"(", "2", ")"}]}]}], ",", " ", 
    RowBox[{"which", " ", "is", " ", "algebraically", " ", "too", " ", 
     RowBox[{"large", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{
      RowBox[{"Element", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "xi1", ",", " ", "xi2", ",", " ", "lam", ",", " ", "eta", ",", " ", 
          "dxm", ",", " ", "dym"}], "}"}], ",", " ", "Reals"}], "]"}], " ", "&&",
       " ", 
      RowBox[{"xi1", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"xi2", " ", ">", " ", "0"}], " ", "&&", " ", 
      RowBox[{"lam", " ", ">", " ", "0"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"b9e71462-dfcc-4089-8c7f-dbf0e0a5ce2b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rhoM", "[", 
    RowBox[{"x_", ",", " ", "y_"}], "]"}], " ", ":=", " ", 
   RowBox[{"eta", " ", 
    RowBox[{"(", "\n", "  ", 
     RowBox[{
      RowBox[{"Cos", "[", 
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", " ", "+", " ", "dym"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", "3", "]"}], " ", "lam"}], ")"}]}]}], "]"}], 
      " ", "+", "\n", "  ", 
      RowBox[{"2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"y", " ", "+", " ", "dym"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sqrt", "[", "3", "]"}], " ", "lam"}], ")"}]}]}], "]"}], 
       " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "Pi", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x", " ", "+", " ", "dxm"}], ")"}], "/", "lam"}]}], 
        "]"}]}]}], "\n", ")"}]}]}], ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"e235069a-7bc2-4c67-9c67-f837e752d8fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Standard", " ", "60"}], "-", 
    RowBox[{"degree", " ", 
     RowBox[{"parallelogram", ".", "\n", "   ", "The"}], " ", "base", " ", 
     "length", " ", "is", " ", "xi2", " ", "lambda", " ", "and", " ", "the", 
     " ", "height", " ", "is", " ", 
     RowBox[{
      RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}], " ", "xi1", " ", 
     RowBox[{"lambda", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"height", " ", "=", " ", 
     RowBox[{
      RowBox[{"Sqrt", "[", "3", "]"}], " ", "xi1", " ", 
      RowBox[{"lam", "/", "2"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"xLeft", "[", "y_", "]"}], " ", ":=", " ", 
     RowBox[{"y", "/", 
      RowBox[{"Sqrt", "[", "3", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"xRight", "[", "y_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"y", "/", 
       RowBox[{"Sqrt", "[", "3", "]"}]}], " ", "+", " ", 
      RowBox[{"xi2", " ", "lam"}]}]}], ";"}]}]}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"c0ea16a9-32a4-4e07-af20-6e5947e1e70a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"energy60Raw", " ", "=", " ", 
   RowBox[{"Integrate", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"rhoM", "[", 
      RowBox[{"x", ",", " ", "y"}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"y", ",", " ", "0", ",", " ", "height"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"x", ",", " ", 
       RowBox[{"xLeft", "[", "y", "]"}], ",", " ", 
       RowBox[{"xRight", "[", "y", "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"GenerateConditions", " ", "->", " ", "False"}]}], "\n", "]"}]}],
   ";"}]], "Input",
 CellLabel->"In[7]:=",ExpressionUUID->"4f4df364-0795-46c0-b9c3-17fc74709919"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Integrate", " ", "sometimes", " ", "writes", " ", "this", " ", 
     "periodic", " ", "phase", " ", "with", " ", 
     RowBox[{
      RowBox[{"FractionalPart", "[", "xi1", "]"}], ".", "\n", "   ", "In"}], 
     " ", "this", " ", "result", " ", "it", " ", "appears", " ", "in", " ", 
     "a", " ", 
     RowBox[{"Cos", "[", "...", "]"}], " ", 
     RowBox[{"Sin", "[", "...", "]"}], " ", "product"}], ",", " ", 
    RowBox[{
    "where", " ", "the", "\n", "   ", "parity", " ", "factors", " ", 
     "cancel"}], ",", " ", 
    RowBox[{"so", " ", "replacing", " ", 
     RowBox[{"FractionalPart", "[", "xi1", "]"}], " ", "by", " ", "xi1", " ", 
     "gives", " ", "an", " ", "equivalent", " ", 
     RowBox[{"form", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"energy60", " ", "=", " ", 
    RowBox[{"FullSimplify", "[", 
     RowBox[{"energy60Raw", " ", "/.", " ", 
      RowBox[{
       RowBox[{"FractionalPart", "[", "xi1", "]"}], " ", "->", " ", "xi1"}]}],
      "]"}]}], ";"}]}]], "Input",
 CellLabel->"In[8]:=",ExpressionUUID->"faeb4499-ab08-43e5-82ef-7b57a7d32592"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"If", " ", "xi2", " ", "is", " ", "an", " ", "integer"}], ",", 
    " ", 
    RowBox[{
     RowBox[{"all", " ", "xi2"}], "-", 
     RowBox[{"dependent", " ", "sine", " ", "terms", " ", 
      RowBox[{"vanish", ".", "\n", "   ", "The"}], " ", "energy", " ", 
      "depends", " ", "only", " ", "on", " ", "dym"}]}], ",", " ", 
    RowBox[{"so", " ", "sliding", " ", "along", " ", "dxm", " ", "is", " ", 
     RowBox[{"frictionless", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"energyXi2Integer", " ", "=", " ", 
     RowBox[{"FullSimplify", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"energy60", " ", "/.", " ", 
        RowBox[{"xi2", " ", "->", " ", "n"}]}], ",", "\n", "  ", 
       RowBox[{"Assumptions", " ", "->", " ", 
        RowBox[{
         RowBox[{"Element", "[", 
          RowBox[{"n", ",", " ", "Integers"}], "]"}], " ", "&&", " ", 
         RowBox[{"n", " ", ">", " ", "0"}], " ", "&&", " ", 
         RowBox[{"xi1", " ", ">", " ", "0"}], " ", "&&", " ", 
         RowBox[{"lam", " ", ">", " ", "0"}]}]}]}], "\n", "]"}]}], ";"}], 
   "\n", 
   RowBox[{"targetXi2Integer", " ", "=", " ", 
    RowBox[{
     RowBox[{"Sqrt", "[", "3", "]"}], " ", "eta", " ", 
     RowBox[{"lam", "^", "2"}], " ", "n", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{
       RowBox[{"4", " ", "Pi", " ", 
        RowBox[{"dym", "/", 
         RowBox[{"(", 
          RowBox[{
