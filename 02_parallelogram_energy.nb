        " ", 
       RowBox[{"Pi", " ", "xi1"}]}], "]"}], " ", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"Pi", " ", "xi1"}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", "Pi"}], ")"}]}]}]}]}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"0aa91703-0fcf-4af6-81ea-768e5e1191be"],

